    {
      "id": "ingest_content",
      "type": "text",
      "x": 72, "y": 543, "width": 371, "height": 155,
      "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "groupIds": [],
      "roundness": null, "seed": 52, "version": 1, "versionNonce": 52,
      "isDeleted": false, "boundElements": [], "updated": 1717632000000,
      "link": null, "locked": false,
      "text": "Extract  →  loader.py\n    PyPDFLoader + OCR fallback\n\nTransform  →  chunker.py\n    chunk_size=2000, overlap=100\n\nTransform  →  embedder.py\n    text-embedding-3-large\n\nLoad  →  vector_store_loader.py\n    batch_size=100",
      "fontSize": 12, "fontFamily": 2,
      "textAlign": "left", "verticalAlign": "top",
